---
import BaseLayout from '../layouts/BaseLayout.astro';
import LineReveal from '../components/LineReveal';

const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');

const readingList = alphabet.map((letter, index) => ({
  letter,
  items: [
    {
      title: `${letter}rticles on taste, systems, and software craft`,
      note: 'A sharp essay worth revisiting when thinking about product feel and technical restraint.',
    },
    {
      title: `${letter} field note on design-heavy web interactions`,
      note: 'A reference for motion, pacing, and how small transitions change perceived quality.',
    },
  ],
}));

const canonicalUrl = new URL('/reading-list/', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Reading List',
  url: canonicalUrl,
  description: 'An A–Z list of interesting reads, references, and saved links.',
};
---

<BaseLayout
  title="Reading List"
  description="An A–Z list of interesting reads, references, and saved links."
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
>
  <div class="page-intro reading-list-intro">
    <p class="eyebrow">Library</p>
    <LineReveal
      as="h1"
      text="A running A–Z reading list of essays, references, and thoughts worth sharing."
      className="page-intro__title"
      stagger={0.085}
      duration={0.62}
      client:load
    />
    <LineReveal
      as="p"
      text="A place to collect links worth returning to. The entries are placeholders for now, but the structure is ready for the real list."
      className="page-intro__lede"
      delay={0.12}
      stagger={0.065}
      duration={0.58}
      client:load
    />
  </div>

  <div class="section-accent" aria-hidden="true">
    <span class="section-accent__square"></span>
    <span class="section-accent__bar"></span>
  </div>

  <nav class="reading-index" aria-label="Reading list alphabet">
    {
      alphabet.map((letter) => (
        <a href={`#reading-${letter}`}>{letter}</a>
      ))
    }
  </nav>

  <div class="reading-list">
    {
      readingList.map((group) => (
        <section class="reading-group" id={`reading-${group.letter}`}>
          <div class="reading-group__heading">
            <p class="reading-group__letter">{group.letter}</p>
            <span class="reading-group__rule" aria-hidden="true"></span>
          </div>
          <ul class="reading-group__items">
            {
              group.items.map((item) => (
                <li>
                  <a href="https://williamgermany.com" target="_blank" rel="noreferrer">
                    <span class="reading-item__title">{item.title}.</span>
                    <span class="reading-item__note">{item.note}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>
      ))
    }
  </div>
</BaseLayout>
